# RAG Service
PORT=8000
DEBUG=true

# Vector Store (Qdrant)
QDRANT_URL=http://62.234.43.230:6333
QDRANT_API_KEY=Wangzi1313#
QDRANT_COLLECTION=tutor_knowledge
QDRANT_USER_MEMORY_COLLECTION=tutor_user_memory
QDRANT_VIDEO_CACHE_COLLECTION=tutor_video_cache

# Embedding Model (sentence-transformers)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024

# Reranker
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_ENABLED=true

# Chunking
MAX_CHUNK_SIZE=512
CHUNK_OVERLAP=0.1
MIN_CHUNK_SIZE=50

# RAG Pipeline
TOP_K_RETRIEVE=20
TOP_K_RERANK=5

# Redis Cache
REDIS_URL=redis://localhost:6379

# LLM (可选，用于 HyDE 查询扩展)
ANTHROPIC_API_KEY=

# tiktoken 编码文件缓存目录（解决网络受限环境下的下载问题）
# TIKTOKEN_CACHE_DIR=/path/to/tiktoken_cache
