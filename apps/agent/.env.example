# Agent Service
PORT=8001
NODE_ENV=development

# ─── LLM Provider ─────────────────────────────────────────────────────────────
# 切换 Provider：anthropic（默认）| doubao
LLM_PROVIDER=anthropic

# Anthropic（LLM_PROVIDER=anthropic 时必填）
ANTHROPIC_API_KEY=

# 豆包·火山引擎（LLM_PROVIDER=doubao 时必填）
# API Key 在火山引擎控制台 → 方舟 → API Key 管理 中获取
DOUBAO_API_KEY=
# BaseURL 默认为北京区，如有其他区域可自行修改
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ─── 依赖服务 ──────────────────────────────────────────────────────────────────
# RAG Service (Python FastAPI)
RAG_SERVICE_URL=http://localhost:8000

# Backend Server (NestJS)
SERVER_URL=http://localhost:3000
INTERNAL_TOKEN=your-internal-service-token

# Optional: Redis (短期记忆，不配置则降级为内存）
REDIS_URL=redis://localhost:6379

# Optional: Manim 渲染服务
MANIM_SERVICE_URL=http://localhost:8002

# Optional: 对象存储上传服务
STORAGE_SERVICE_URL=http://localhost:8003
